# URL pubblica dell'Auth Gateway. Il frontend non chiama direttamente i microservizi.
VITE_API_BASE_URL=http://localhost:8282

# Client OAuth2 registrato nel database PostgreSQL dell'auth-gateway.
# In una SPA il valore non è un segreto reale: usare un client dedicato e limitato al password grant locale.
VITE_AUTH_CLIENT_ID=documed-web
VITE_AUTH_CLIENT_SECRET=replace-with-local-oauth-client-secret
