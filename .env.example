# Porte pubbliche: database e microservizi restano sulla rete Docker interna.
FRONTEND_PORT=3000
AUTH_GATEWAY_PORT=8282

# Chiave condivisa di demo. Sostituire in ogni ambiente non locale (minimo 32 caratteri).
JWT_SIGNING_KEY=documed-local-demo-jwt-signing-key-change-me-2026
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
APP_TIME_ZONE=Europe/Rome

# PostgreSQL locale, condiviso tramite schemi separati da Patient e Auth Service.
POSTGRES_DB=documed_patient
POSTGRES_USER=documed
POSTGRES_PASSWORD=documed-local-password

# MongoDB locale, usato esclusivamente da Document Service e GridFS.
MONGO_USERNAME=platform
MONGO_PASSWORD=platform-local-password

# Account ADMIN e client OAuth2 inseriti nello schema PostgreSQL auth_service
# dalla migrazione Flyway. Lasciare vuoti i quattro valori per non creare dati demo.
# Password demo amministratore: AdminDemo123!
DEMO_ADMIN_USERNAME=admin
DEMO_ADMIN_PASSWORD_HASH='$2y$10$oy38uAIXwEjcUB7M1BuilOkZwZGlrAO8bCH80RyAgX1aImOKzZRV2'
DEMO_OAUTH_CLIENT_ID=documed-web
DEMO_OAUTH_CLIENT_SECRET=DocuMedWebDemo123!
DEMO_OAUTH_CLIENT_SECRET_HASH='$2y$10$ZEX3Hi09o8JwKdVjekSqLu6dxv4ctTQ2ReV.lL9CGmuobtGd3OBGG'

# OCR sincrono.
OCR_LANGUAGE=ita
OCR_TIMEOUT_SECONDS=60
