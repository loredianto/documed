# Runtime
OCR_SERVICE_PORT=8083
SERVER_PORT=8083

# Must be identical to the Auth Gateway signing key and at least 32 characters.
JWT_SIGNING_KEY=replace-with-the-same-auth-gateway-secret-32-chars

# Tesseract
TESSERACT_COMMAND=tesseract
OCR_LANGUAGE=ita
OCR_TIMEOUT_SECONDS=60

# Upload limits
OCR_MAX_FILE_SIZE=10MB
OCR_MAX_REQUEST_SIZE=11MB
OCR_MAX_FILE_SIZE_BYTES=10485760
