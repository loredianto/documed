# Runtime
PATIENT_SERVICE_PORT=8081
SERVER_PORT=8081
APP_TIME_ZONE=Europe/Rome

# PostgreSQL is started from DBs/PostgreSQL/docker-compose.yml.
DATABASE_URL=jdbc:postgresql://postgres:5432/documed_patient
DATABASE_USERNAME=documed
DATABASE_PASSWORD=documed-local-password

# Must be identical to the Auth Gateway signing key and at least 32 characters.
JWT_SIGNING_KEY=replace-with-the-same-auth-gateway-secret-32-chars
