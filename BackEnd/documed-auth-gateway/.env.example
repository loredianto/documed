# Runtime
AUTH_GATEWAY_PORT=8282
SERVER_PORT=8282

# MongoDB started from DBs/MongoDB/docker-compose.yml
MONGODB_URI=mongodb://platform:platform-local-password@mongodb:27017/auth_service?authSource=admin

# Required in every environment. Generate a random secret of at least 32 characters.
JWT_SIGNING_KEY=replace-with-random-secret-at-least-32-characters

# Browser and future services
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
PATIENT_SERVICE_URL=http://patient-service:8081
DOCUMENT_SERVICE_URL=http://document-service:8082

# Proxy and multipart limits. The request limit includes multipart overhead.
GATEWAY_CONNECT_TIMEOUT_MS=5000
GATEWAY_SOCKET_TIMEOUT_MS=75000
GATEWAY_MAX_FILE_SIZE=10MB
GATEWAY_MAX_REQUEST_SIZE=11MB
