# Runtime
AUTH_GATEWAY_PORT=8282
SERVER_PORT=8282

# PostgreSQL started from DBs/PostgreSQL/docker-compose.yml.
# Auth tables are isolated in the auth_service schema.
DATABASE_URL=jdbc:postgresql://postgres:5432/documed_patient
DATABASE_USERNAME=documed
DATABASE_PASSWORD=documed-local-password

# Optional local demo rows inserted by Flyway. Leave empty outside local demos.
DEMO_ADMIN_USERNAME=
DEMO_ADMIN_PASSWORD_HASH=
DEMO_OAUTH_CLIENT_ID=
DEMO_OAUTH_CLIENT_SECRET_HASH=

# Required in every environment. Generate a random secret of at least 32 characters.
JWT_SIGNING_KEY=replace-with-random-secret-at-least-32-characters

# Browser and future services
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
PATIENT_SERVICE_URL=http://patient-service:8081
DOCUMENT_SERVICE_URL=http://document-service:8082

# Proxy and multipart limits. The request limit includes multipart overhead.
GATEWAY_CONNECT_TIMEOUT_MS=5000
GATEWAY_SOCKET_TIMEOUT_MS=75000
GATEWAY_MAX_FILE_SIZE=10MB
GATEWAY_MAX_REQUEST_SIZE=11MB
