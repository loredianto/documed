# Runtime
DOCUMENT_SERVICE_PORT=8082
SERVER_PORT=8082

# MongoDB is started from DBs/MongoDB/docker-compose.yml.
MONGODB_URI=mongodb://platform:platform-local-password@mongodb:27017/document_service?authSource=admin

# Must be identical to the Auth Gateway signing key and at least 32 characters.
JWT_SIGNING_KEY=replace-with-the-same-auth-gateway-secret-32-chars

# Patient Service integration
PATIENT_SERVICE_URL=http://patient-service:8081
PATIENT_SERVICE_CONNECT_TIMEOUT_MS=3000
PATIENT_SERVICE_READ_TIMEOUT_MS=5000

# OCR Service integration
OCR_SERVICE_URL=http://ocr-service:8083
OCR_SERVICE_CONNECT_TIMEOUT_MS=3000
OCR_SERVICE_READ_TIMEOUT_MS=65000

# Upload limits. Keep servlet and application limits aligned.
DOCUMENT_MAX_FILE_SIZE=10MB
DOCUMENT_MAX_REQUEST_SIZE=11MB
DOCUMENT_MAX_FILE_SIZE_BYTES=10485760
